# Workspace configuration
shamefully-hoist=true

# Use pnpm's strict peer dependencies
strict-peer-dependencies=false

# Enable auto-install-peers for easier dependency management
auto-install-peers=true

# Lockfile settings
lockfile=true

# Store configuration
# store-dir=~/.pnpm-store

# Electron native modules - allow build on install
# This is needed for better-sqlite3
node-linker=hoisted

# Shared workspace lockfile
shared-workspace-lockfile=true

# Public hoist pattern (for Electron/native modules)
public-hoist-pattern[]=*sqlite*
public-hoist-pattern[]=*electron*
public-hoist-pattern[]=*esbuild*

# Logging
loglevel=warn

# Save exact versions
save-exact=false

# Enable side-effects cache
side-effects-cache=true

# Prefer workspace packages
prefer-workspace-packages=true
