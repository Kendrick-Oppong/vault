{
  "name": "vault",
  "version": "0.1.0",
  "private": true,
  "description": "A fast, modern desktop YouTube downloader — powered by yt-dlp & FFmpeg",
  "author": "Kendrick-Oppong",
  "license": "MIT",
  "homepage": "https://github.com/Kendrick-Oppong/vault",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kendrick-Oppong/vault.git"
  },
  "scripts": {
    "dev:vault": "pnpm --filter vault dev",
    "dev:web": "pnpm --filter web dev",
    "build:vault": "pnpm --filter vault build",
    "build:web": "pnpm --filter web build",
    "format": "prettier --write .",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "prettier": "^3.7.4"
  }
}
